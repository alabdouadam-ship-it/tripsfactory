**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Next.js / Web (Admin folder)
admin/node_modules/
admin/.next/
admin/out/
admin/.env.local
admin/.env.development.local
admin/.env.test.local
admin/.env.production.local
admin/next-env.d.ts
admin/*.tsbuildinfo

# Generic ignores
node_modules/
.env*
!.env.example
*.log


# Kiro IDE
.kiro/

# Firebase admin credentials — never commit
assets/tripsfactory-logistics-firebase-adminsdk.json
*firebase-adminsdk*.json

# Firebase client config — per-fork; ship the *.example templates instead.
# Each buyer generates these from their own Firebase project.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Firebase Hosting deploy caches (generated each deploy)
.firebase/

# Claude Code local config
.claude/

# Local secrets staging folder (service accounts, keys) — never commit
supabase/secret/

# Supabase CLI local state (link target, version pins) — machine-specific
supabase/.temp/

# Private seller/distribution notes (never ship or commit these)
*.private.md
