# Admin control panel — Supabase connection.
# Copy this file to `admin/.env.local` (gitignored) and fill with YOUR Supabase
# project's values (Supabase Dashboard -> Settings -> API). The admin uses only
# the public anon key (Row-Level Security enforces access). See docs/GETTING_STARTED.md.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
