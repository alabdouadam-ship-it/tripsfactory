{
  "hosting": [
    {
      "target": "legal",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "/SYSTEM_AUDIT.html",
          "destination": "/system_audit.html",
          "type": 301
        }
      ],
      "rewrites": [
        { "source": "/trip/**", "destination": "/trip.html" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "admin",
      "public": "admin/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**/*.@(js|css|json)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        { "source": "/users/*", "destination": "/users/placeholder.html" },
        { "source": "/bookings/*", "destination": "/bookings/placeholder.html" },
        { "source": "/shipments/*", "destination": "/shipments/placeholder.html" },
        { "source": "/trips/*", "destination": "/trips/placeholder.html" }
      ],
      "cleanUrls": true
    }
  ]
}
